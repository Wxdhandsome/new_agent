# ===========================================
# 环境变量与敏感配置 (最高优先级)
# ===========================================

# 所有环境变量文件（除示例外）
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.example
!.env.template

# 前端环境变量
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/.env.development
frontend/.env.production
!frontend/.env.example

# 后端环境变量
backend/.env
backend/.env.local
backend/.env.*.local
!backend/.env.example

# ===========================================
# Python / 后端
