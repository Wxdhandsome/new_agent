# ===========================================
# Workflow AI 工作流系统环境配置
# 复制此文件为 .env 并修改配置
# ===========================================

# -------------------------------------------
# 基础配置 (必需)
# -------------------------------------------
DATABASE_URL=sqlite:///./workflow.db
SECRET_KEY=your-secret-key-here-change-in-production

# -------------------------------------------
# LLM API 配置 (必需 - 用于大模型节点)
# -------------------------------------------
# API密钥 - 用于访问LLM服务
API_KEY=your-api-key-here
# LLM服务地址 - OpenAI格式API地址
BASE_URL=http://localhost:8000/v1

# OpenAI 官方 API 密钥 (如果使用OpenAI官方服务)
# OPENAI_API_KEY=your-openai-api-key-here

# -------------------------------------------
# 后端服务配置 (可选，通常保持默认)
# -------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# -------------------------------------------
# BGE Embedding 服务配置 (必需 - 用于知识库)
# -------------------------------------------
# BGE服务地址 - 提供文本向量化服务
# 例如: http://localhost:50183 或 http://1.194.201.134:50183
BGE_URL=http://localhost:50183
# 向量维度（1024为BGE-large-en-v1.5等模型默认维度，一般无需修改）
BGE_DENSE_DIM=1024

# -------------------------------------------
# Milvus 向量数据库配置 (必需 - 用于知识库存储)
# -------------------------------------------
# Milvus 服务器地址
# 例如: localhost 或 192.168.99.151
MILVUS_HOST=localhost
# Milvus 端口（默认19530）
MILVUS_PORT=19530
# 集合名称（无需修改，系统会自动创建）
MILVUS_COLLECTION=workflow_kb_hybrid
